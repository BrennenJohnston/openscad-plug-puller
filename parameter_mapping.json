  "title": "Plug Puller 0.8 Parameter Mapping",
  "description": "Machine-readable schema for every user-facing Customizer parameter declared in src/Plug_Puller_Parametric.scad. Source of truth for the parameter schema validator (tests/validate_parameter_schema.py) and the CI lint stage. Generated by scripts/generate_parameter_mapping.py.",
  "version": "1.0.0",
  "last_updated": "2026-07-13",
  "documentation": "Plug Puller 0.8 has a single front-end (OpenSCAD itself); this file only checks default values, types, slider ranges, and enum option lists against the SCAD. A `tool_style` selector switches between the flat tool and the heavy-duty clamshell; plug measurements are always active except in Custom mode or when a plug preset is chosen.",
  "ui_parameter_format": {
    "description": "OpenSCAD Customizer dropdown format guidelines.",
    "correct_format": "param = \"DefaultLabel\"; // [Label1, Label2, Label3]",
    "guidelines": [
      "Use human-readable labels as values (e.g. `\"Medium\"`).",
      "The default value must exactly match one of the dropdown options.",
      "Numeric `[min:step:max]` sliders are validated against the `range` field."
    ]
  },
